  "sim2real_focus": {
    "goal": "Use staged real-robot tests to identify which deployment-side parameters need adaptation without changing the trained policy first.",
    "recommended_test_sequence": [
      {
        "stage": "sensor_and_sign_check",
        "purpose": "Verify IMU, joint order, joint sign, joystick direction, and zero offsets before enabling RL.",
        "watch_items": [
          "Joint position sign matches intended positive direction",
          "IMU orientation and angular velocity axes are consistent with controller expectation",
          "joint_offset and actuator zeroing are correct",
          "Commanded forward, lateral, yaw inputs move in expected direction"
        ],
        "primary_tuning_targets": [
          "joint_offset",
          "joint_limits",
          "ROS topic mapping or sensor frame alignment"
        ]
      },
      {
        "stage": "stand_transition",
        "purpose": "Check zero -> stand and stand hold stability before RL walking.",
        "watch_items": [
          "Overshoot during transition",
          "High-frequency oscillation in hips, knees, ankles",
          "Steady-state pose bias relative to desired stand posture",
          "Motor heating or sustained torque"
        ],
        "primary_tuning_targets": [
          "pd_zero and pd_stand stiffness",
          "pd_zero and pd_stand damping",
          "joint_offset"
        ]
      },
      {
        "stage": "rl_idle_and_in_place_step",
        "purpose": "Enable rl_walk_leg with zero or very small velocity command and observe whether policy remains calm.",
        "watch_items": [
          "Whether sw_mode and cmd_threshold cause unintended stepping at zero command",
          "Ankle chatter caused by torque-mode parallel joints",
          "Action saturation or repeated clipping",
          "Low-pass delay versus responsiveness"
        ],
        "primary_tuning_targets": [
          "walk_step_conf.cmd_threshold",
          "walk_step_conf.sw_mode",
          "lpf_conf.wc",
          "stiffness and damping for ankle and knee joints",
          "action_scale"
        ]
      },
      {
        "stage": "low_speed_walk",
        "purpose": "Start with conservative forward speed on flat ground and compare tracking, cadence, and foot clearance against sim.",
        "watch_items": [
          "Step length too large or too small",
          "Toe scuffing or insufficient foot clearance",
          "Body pitch or roll drift",
          "Velocity tracking lag",
          "Asymmetry between left and right stance"
        ],
        "primary_tuning_targets": [
          "action_scale",
          "cycle_time",
          "obs_scales.lin_vel",
          "obs_scales.ang_vel",
          "leg joint stiffness and damping"
        ]
      },
      {
        "stage": "lateral_and_yaw_commands",
        "purpose": "Test y-axis and yaw commands separately after forward walking is stable.",
        "watch_items": [
          "Unexpected coupling between yaw and roll",
          "Lateral slip or strong upper-body compensation",
          "Turning overshoot or understeer"
        ],
        "primary_tuning_targets": [
          "obs_scales.lin_vel",
          "obs_scales.ang_vel",
          "action_scale",
          "cycle_time"
        ]
      },
      {
        "stage": "disturbance_and_contact_robustness",
        "purpose": "Apply mild pushes and test on slightly different friction or floor stiffness after baseline walking is stable.",
        "watch_items": [
          "Recovery delay",
          "Ankle saturation",
          "Foot slap on landing",
          "Instability after impact"
        ],
        "primary_tuning_targets": [
          "ankle stiffness and damping",
          "lpf_conf.wc",
          "joint_limits",
          "action_scale"
        ]
      }
    ],
    "symptom_to_parameter_hints": [
      {
        "symptom": "Robot reacts too aggressively or step amplitude is too large",
        "check": [
          "action_scale too high",
          "stiffness too high",
          "cycle_time too short"
        ]
      },
      {
        "symptom": "Robot is sluggish, drags feet, or fails to commit to step",
        "check": [
          "action_scale too low",
          "stiffness too low",
          "damping too high",
          "lpf_conf.wc too low"
        ]
      },
      {
        "symptom": "High-frequency oscillation or audible chatter",
        "check": [
          "stiffness too high",
          "damping too low",
          "IMU noise or joint velocity noise",
          "lpf_conf.wc too high"
        ]
      },
      {
        "symptom": "Ankle torque joints feel unstable or vibrate under load",
        "check": [
          "ankle stiffness or damping mismatch",
          "lpf_conf.wc not suitable for torque-mode path",
          "joint offset or sign error"
        ]
      },
      {
        "symptom": "Zero command still causes stepping",
        "check": [
          "walk_step_conf.cmd_threshold too small",
          "joystick deadband mismatch",
          "cmd topic has residual noise",
          "sw_mode behavior not matching expectation"
        ]
      }
    ]
  }
